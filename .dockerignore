.idea/
.vscode/
*.swp
*.swo

# Git
.git/
.gitignore

# Docker 自身
Dockerfile
docker-compose.yml
.dockerignore

# 数据库文件（运行时产生）
*.db
*.sqlite
*.sqlite3
